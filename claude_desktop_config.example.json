{
  "mcpServers": {
    "santa-fe-half-marathon": {
      "command": "python",
      "args": ["/absolute/path/to/santa_fe_race_mcp/server.py"],
      "env": {
        "REGISTRATION_BACKEND": "runsignup",
        "RUNSIGNUP_API_KEY": "your-key",
        "RUNSIGNUP_API_SECRET": "your-secret",
