# Copy to .env and fill in the block you need.
# Never commit .env — it's in .gitignore.

# --- Backend selector ---
REGISTRATION_BACKEND=json   # json | airtable | runsignup | raceroster

# --- Airtable ---
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=

# --- RunSignup ---
RUNSIGNUP_API_KEY=
RUNSIGNUP_API_SECRET=
RUNSIGNUP_RACE_ID=83604
RUNSIGNUP_EVENT_ID=1056101

# --- RaceRoster ---
RACEROSTER_PARTICIPANTS_URL=
RACEROSTER_TOKEN=

# --- GitHub MCP server (optional, for the claude CLI — see GITHUB_MCP_SETUP.md) ---
# Fine-grained PAT from https://github.com/settings/personal-access-tokens
GITHUB_PAT=

# --- Server transport ---
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8000
